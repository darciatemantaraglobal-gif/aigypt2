# ──────────────────────────────────────────────────────────────────────────────
# AIGYPT — Environment Variables
# Salin file ini menjadi .env dan isi nilainya.
# Jangan pernah commit file .env ke git!
# ──────────────────────────────────────────────────────────────────────────────

# URL backend API (Express server).
# Di Replit: kosongkan (frontend & backend satu origin).
# Di Vercel: isi dengan URL deployed API server, misal https://aigypt-api.railway.app
VITE_API_URL=

# Nomor WhatsApp untuk tombol kontak (format internasional tanpa +)
# Contoh: 6281234567890
VITE_WA_NUMBER=628xxxxxxxxxx

# ──────────────────────────────────────────────────────────────────────────────
# Variabel berikut diisi otomatis oleh Replit / Vercel — jangan diisi manual
# ──────────────────────────────────────────────────────────────────────────────
# PORT=
# BASE_PATH=/
